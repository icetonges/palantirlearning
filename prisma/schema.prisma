// ─────────────────────────────────────────────────────────────────────────────
// Palantir Learning Platform — Prisma Schema
// DB: Neon PostgreSQL (serverless)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum KnowledgeCategory {
  FOUNDRY
  ONTOLOGY
  AIP
  APOLLO
  GENERAL
  NEWS
  RESOURCES
}

enum SourceType {
  NOTE       // Manual text note
  UPLOAD     // Uploaded PDF/DOCX/TXT
  SCRAPED    // Auto-scraped from web
  SEEDED     // Pre-loaded official documentation
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ResourceType {
  DOCUMENTATION
  SDK
  GITHUB
  YOUTUBE
  ARTICLE
  COURSE
  COMMUNITY
  TOOL
}

enum NewsTag {
  FOUNDRY
  ONTOLOGY
  AIP
  APOLLO
  CONTRACT
  EARNINGS
  PARTNERSHIP
  CRITICISM
  RELEASE
  GENERAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

/// Auto-generated knowledge pages from notes, uploads, or scraped docs
model KnowledgePage {
  id           String            @id @default(cuid())
  category     KnowledgeCategory
  slug         String            @unique
  title        String
  content      String            // Full markdown content
  excerpt      String?           // Auto-generated 2-sentence excerpt
  aiSummary    String?           // Gemini-generated summary
  tags         String[]          // Extracted topic tags
  sourceType   SourceType        @default(NOTE)
  subCategory  String?           // e.g. "Transforms", "Actions", "AIP Logic"
  pinned       Boolean           @default(false)
  flashcardCount Int             @default(0)
  viewCount    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  flashcards   Flashcard[]       // Cards generated from this page

  @@index([category])
  @@index([slug])
  @@index([createdAt])
  @@index([subCategory])
  @@map("knowledge_pages")
}

/// Daily scraped news items from all sources
model NewsItem {
  id          String    @id @default(cuid())
  title       String
  summary     String    // Original excerpt from source
  aiSummary   String?   // Gemini 2-sentence summary
  source      String    // e.g. "Palantir Blog", "Hacker News", "Reuters"
  url         String    @unique
  urlHash     String    @unique // SHA-256 of URL for dedup check
  tags        NewsTag[] @default([GENERAL])
  category    KnowledgeCategory @default(NEWS)
  publishedAt DateTime?
  scrapedAt   DateTime  @default(now())
  featured    Boolean   @default(false)

  @@index([scrapedAt])
  @@index([tags])
  @@map("news_items")
}

/// AI-generated executive summary for each scrape run (usually daily)
model DailySummary {
  id            String   @id @default(cuid())
  summaryDate   DateTime @unique // Date this covers (midnight UTC)
  content       String   // Full markdown executive briefing
  topicsCount   Int      @default(0)
  articlesCount Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([summaryDate])
  @@map("daily_summaries")
}

/// Study flashcards — can be auto-generated or manually created
model Flashcard {
  id              String            @id @default(cuid())
  category        KnowledgeCategory
  subCategory     String?
  question        String
  answer          String
  difficulty      Difficulty        @default(MEDIUM)
  tags            String[]
  sourcePageId    String?           // Link back to KnowledgePage if generated
  sourcePage      KnowledgePage?    @relation(fields: [sourcePageId], references: [id], onDelete: SetNull)
  timesReviewed   Int               @default(0)
  timesCorrect    Int               @default(0)
  lastReviewedAt  DateTime?
  createdAt       DateTime          @default(now())

  @@index([category])
  @@index([difficulty])
  @@map("flashcards")
}

/// Completed quiz sessions for progress tracking
model QuizSession {
  id           String            @id @default(cuid())
  category     KnowledgeCategory
  score        Int
  total        Int
  percentage   Float
  answersJson  Json              // Full Q&A results array
  takenAt      DateTime          @default(now())

  @@index([category])
  @@index([takenAt])
  @@map("quiz_sessions")
}

/// Curated resource links (official docs, SDKs, GitHub, YouTube, etc.)
model Resource {
  id           String            @id @default(cuid())
  category     KnowledgeCategory
  title        String
  url          String            @unique
  description  String
  resourceType ResourceType
  isPinned     Boolean           @default(false)
  isOfficial   Boolean           @default(false)
  createdAt    DateTime          @default(now())

  @@index([category])
  @@index([resourceType])
  @@map("resources")
}

/// Uploaded document metadata
model Document {
  id           String            @id @default(cuid())
  filename     String
  originalName String
  blobUrl      String?           // Vercel Blob URL
  mimeType     String
  sizeBytes    Int
  category     KnowledgeCategory
  processed    Boolean           @default(false)
  pageSlug     String?           // Slug of the KnowledgePage created from this
  createdAt    DateTime          @default(now())

  @@map("documents")
}

/// Auth: sessions (NextAuth v5 + Prisma adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// Daily AI-generated learning content — two sections, cached per date
model DailyLesson {
  id             String   @id @default(cuid())
  lessonDate     DateTime @unique // Midnight UTC of the day
  topicTitle     String           // e.g. "Pipeline Builder — Incremental Transforms"
  topicDomain    String           // e.g. "FOUNDRY"
  topicSubject   String           // e.g. "Transforms"
  topicBody      String           // ~400 word structured essay
  palantir101    String           // ~400 word tech stack + learning strategy
  createdAt      DateTime @default(now())

  @@index([lessonDate])
  @@map("daily_lessons")
}
