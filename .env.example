# ─── DATABASE (Neon PostgreSQL) ────────────────────────────────────────────────
# Get from: https://console.neon.tech → Your project → Connection Details
# Use the POOLED connection string for DATABASE_URL (required for Vercel serverless)
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Use the DIRECT (non-pooled) connection for migrations
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── NEXTAUTH ──────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-random-string-here"

# Your deployed URL (no trailing slash)
NEXTAUTH_URL="https://palantirlearning.vercel.app"

# ─── GOOGLE OAUTH ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Authorized redirect URIs: https://palantirlearning.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── OWNER AUTHENTICATION ──────────────────────────────────────────────────────
# Only this Google account can log in. Must match exactly.
OWNER_EMAIL="your.email@gmail.com"

# Optional fallback passphrase login
PASSPHRASE="your-secret-passphrase"

# ─── GOOGLE GEMINI AI ──────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ─── SCRAPER SECURITY TOKEN ────────────────────────────────────────────────────
# Any strong random string — used by GitHub Actions to authenticate scraper POSTs
# Generate: openssl rand -hex 32
SCRAPER_TOKEN="your-scraper-bearer-token"

# ─── APP URL (used by Python scraper in GitHub Actions) ────────────────────────
SITE_URL="https://palantirlearning.vercel.app"

# ─── VERCEL BLOB (for document uploads) ────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN="vercelblob_rw_your_token_here"

# ─── NEWS API (supplemental news source) ───────────────────────────────────────
# Free tier at: https://newsapi.org/register
NEWSAPI_KEY="your-newsapi-key"

# ─── GITHUB TOKEN (for Palantir GitHub repo scraping) ──────────────────────────
# Create at: https://github.com/settings/tokens → Fine-grained → public repos read
GITHUB_TOKEN="ghp_your_github_personal_access_token"

# ─── NODEMAILER / GMAIL SMTP (for contact form, optional) ──────────────────────
# Enable 2FA on Gmail → App Passwords → Generate one for "Mail"
EMAIL_USER="your.email@gmail.com"
EMAIL_PASS="your-gmail-app-password"
